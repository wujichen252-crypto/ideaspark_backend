{
  "openapi": "3.0.3",
  "info": {
    "title": "IdeaSpark API",
    "version": "0.0.1"
  },
  "paths": {
    "/api/market/projects/list": {
      "get": {
        "tags": [
          "ProjectMarket"
        ],
        "summary": "获取项目市场列表",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "项目名称模糊搜索关键字"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "项目分类"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1,
              "minimum": 1
            },
            "description": "页码"
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20,
              "minimum": 1,
              "maximum": 200
            },
            "description": "每页数量"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectMarketListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/market/projects/detail": {
      "get": {
        "tags": [
          "ProjectMarket"
        ],
        "summary": "获取项目市场详情",
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "项目ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectMarketDetailResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectMarketListItem": {
        "type": "object",
        "properties": {
          "projectImage": {
            "type": "string"
          },
          "projectName": {
            "type": "string"
          },
          "ownerName": {
            "type": "string"
          },
          "ownerAvatar": {
            "type": "string"
          },
          "likeCount": {
            "type": "integer",
            "format": "int64"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ProjectMarketListResponseData": {
        "type": "object",
        "properties": {
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectMarketListItem"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ProjectMarketListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "获取成功"
          },
          "data": {
            "$ref": "#/components/schemas/ProjectMarketListResponseData"
          }
        }
      },
      "ProjectMarketDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "detailedDescription": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "coverUrl": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "currentModule": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "progress": {
            "type": "integer",
            "format": "int32"
          },
          "visibility": {
            "type": "string"
          },
          "allowFork": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "parentId": {
            "type": "string"
          },
          "ownerId": {
            "type": "integer",
            "format": "int64"
          },
          "ownerName": {
            "type": "string"
          },
          "ownerAvatar": {
            "type": "string"
          },
          "teamId": {
            "type": "string"
          },
          "teamName": {
            "type": "string"
          },
          "teamAvatar": {
            "type": "string"
          },
          "teamIsPersonal": {
            "type": "boolean"
          },
          "teamSize": {
            "type": "integer",
            "format": "int32"
          },
          "likeCount": {
            "type": "integer",
            "format": "int64"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ProjectMarketDetailResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "获取成功"
          },
          "data": {
            "$ref": "#/components/schemas/ProjectMarketDetail"
          }
        }
      }
    }
  }
}
