# IdeaSpark 后端环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置 (必填)
# ============================================
DB_URL=jdbc:mysql://localhost:3306/ideaspark?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# 数据库连接池配置 (可选，使用默认值)
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=5
DB_CONN_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_VALIDATION_TIMEOUT=5000

# ============================================
# JWT 配置 (必填)
# ============================================
# 建议使用 Base64 编码的 32 字节随机密钥
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRE_SECONDS=604800
JWT_ISSUER=ideaspark

# ============================================
# 阿里云 OSS 配置 (可选)
# ============================================
OSS_ENABLED=true
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=ideaspark
OSS_BASE_DIR=uploads

# ============================================
# 服务器配置 (可选)
# ============================================
SERVER_PORT=8081

# ============================================
# 日志配置 (可选)
# ============================================
LOG_LEVEL=DEBUG
LOG_FILE_PATH=logs/ideaspark.log
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_HISTORY=30
HIBERNATE_LOG_SQL=DEBUG
HIBERNATE_LOG_BIND=TRACE

# ============================================
# JPA 配置 (可选)
# ============================================
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true

# ============================================
# Flyway 配置 (可选)
# ============================================
FLYWAY_ENABLED=true

# ============================================
# API 文档配置 (可选)
# ============================================
SWAGGER_ENABLED=true

# ============================================
# CORS 配置 (可选)
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ============================================
# 限流配置 (可选)
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL=10
RATE_LIMIT_PERIOD=1
